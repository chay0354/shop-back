SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PORT=4000

# CardCom (Open Fields). For LIVE/real charges use production terminal + API name from CardCom back office (Settings > Company Setup > Manage API-keys). For testing use test terminal credentials.
CARDCOM_TERMINAL_NUMBER=1000
CARDCOM_API_NAME=cardtest1994
CARDCOM_URL=https://secure.cardcom.solutions

# SendGrid – invoice email (optional). Create API key at sendgrid.com. Use verified sender as FROM.
SENDGRID_API_KEY=
INVOICE_FROM_EMAIL=your-verified-sender@example.com
